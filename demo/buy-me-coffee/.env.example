# NodeRails API (server-side only — never expose secret key to the browser)
NODERAILS_APP_ID=
NODERAILS_API_KEY=nr_test_sk_...

# NodeRails API base URL
NODERAILS_API_URL=https://api.noderails.com

# Hosted payment pages (payment-ui)
PAYMENT_UI_URL=https://pay.noderails.com

# This app's public URL — used for success/cancel redirects AND webhook registration
# Production example: https://buy-me-coffee.yourdomain.com
APP_BASE_URL=http://localhost:3005

# --- Vercel deploy ---
# 1. Import this repo (or demo/buy-me-coffee only) as a new Vercel project
# 2. Root Directory: demo/buy-me-coffee
# 3. Framework: Next.js (vercel.json sets npm install + npm run build)
# 4. Add all env vars below in Vercel → Settings → Environment Variables
# 5. Webhook URL to register in NodeRails dashboard:
#      https://YOUR-VERCEL-DOMAIN/api/webhooks/noderails

# Webhook signing secret from merchant dashboard (Settings → Webhooks → whsec_...)
NODERAILS_WEBHOOK_SECRET=whsec_...

# Register this URL in NodeRails dashboard:
#   ${APP_BASE_URL}/api/webhooks/noderails
# Subscribe to: payment.captured, payment.settled, subscription.activated

# Sui-only checkout (NodeRails chain IDs: 201 devnet, 202 testnet, 203 mainnet)
NODERAILS_SUI_CHAIN_ID=202
NODERAILS_ALLOWED_TOKENS=SUI-202,USDC-202

# Optional — reuse existing subscription plan instead of creating one per demo
# NODERAILS_MONTHLY_PLAN_ID=
# NODERAILS_MONTHLY_PRICE_ID=
