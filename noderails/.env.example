# Environment Variables
# Copy this file to .env and fill in your values

# ============ Database ============
DATABASE_URL="postgresql://user:password@localhost:5432/noderails?schema=public"

# ============ Redis ============
REDIS_URL="redis://localhost:6379"

# ============ Server ============
NODE_ENV=development
PORT=3000
# Comma-separated origins (*.noderails.com is always allowed in production)
CORS_ORIGIN="http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004"
LOG_LEVEL=debug

# ============ Auth ============
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars

# ============ Admin ============
ADMIN_EMAIL=admin@noderails.com
ADMIN_PASSWORD=change-me-in-production

# ============ MTXM (Transaction Manager) ============
MTXM_BASE_URL=http://localhost:8080
MTXM_PROJECT_ID=
MTXM_API_KEY=
# Secret for verifying POST bodies from MTXM → NodeRails (see /webhooks/mtxm).
MTXM_WEBHOOK_SECRET=
# In MTXM/project webhooks, URL must be your public API + /webhooks/mtxm (a wrong host/path returns HTML 404).
# Base58 pubkey of the MTXM-managed Solana signer (must match escrow authorized keys / MTXM signer for this chain)
MTXM_SOLANA_SIGNER_PUBKEY=
# MTXM signer row id (from Signers API / dashboard). Required for SPL capture: sends `solana.transactionBase64` because Ed25519 ixs have empty `keys` and MTXM rejects `instructions[]` for that.
MTXM_SOLANA_SIGNER_ID=
# Solana protocol caps one transaction at 1_400_000 CUs (devnet/mainnet); higher values are clamped.
MTXM_SOLANA_CU_LIMIT=1400000
# Optional: priority fee in micro-lamports per CU (e.g. 1000)
# MTXM_SOLANA_CU_PRICE_MICRO_LAMPORTS=

# ============ Indexer (Event Listener) ============
INDEXER_WEBHOOK_SECRET=

# ============ Prices ============
CRYPTOCOMPARE_API_KEY=

# ============ Fraud Engine (Solana wallet screening) ============
# Sibling checkout ../noderails-fraud-engine; HTTP API docs in that repo docs/API.md
FRAUD_ENGINE_URL=http://127.0.0.1:8788
# Must match FRAUD_ENGINE_API_TOKEN on the fraud engine when that token is set
FRAUD_ENGINE_CLIENT_TOKEN=

# ============ Production URLs ============
# Canonical public domains used across services/apps in production.
API_URL=https://api.noderails.com
DASHBOARD_URL=https://merchant.noderails.com
PAYMENT_UI_URL=https://pay.noderails.com

# ============ Frontend (Next.js Public Env) ============
# Public env vars exposed to browser bundles.
NEXT_PUBLIC_API_URL=https://api.noderails.com
NEXT_PUBLIC_DASHBOARD_URL=https://merchant.noderails.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WC_PROJECT_ID=

# Dodo Payments test checkout (payment-ui). `next.config.mjs` also merges NEXT_PUBLIC_* from repo root `.env` / `.env.local` if unset in this app.
# URL must be https://test.dodopayments.com/... or https://test.checkout.dodopayments.com/... (test mode).
# NEXT_PUBLIC_ENABLE_DODO_PAYMENTS_DEMO=true
# NEXT_PUBLIC_DODO_PAYMENTS_TEST_CHECKOUT_URL=https://test.checkout.dodopayments.com/buy/...

# ============ AWS (SES + SQS) ============
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@noderails.com
# SQS queue URL for SES bounce/complaint/delivery notifications (SES → SNS → SQS)
SES_SQS_QUEUE_URL=

# ============ Dev / Test ============
# Enable short subscription intervals for testing (DO NOT use in production)
ENABLE_TEST_INTERVALS=false
# Enable short escrow timelocks for testing (DO NOT use in production)
ENABLE_TEST_TIMELOCKS=false

# ============ Setup CLI ============
# Only needed when running services/setup-cli
INDEXER_BASE_URL=http://localhost:8081
INDEXER_API_KEY=
NODERAILS_MTXM_WEBHOOK_URL=http://localhost:3000/webhooks/mtxm
NODERAILS_INDEXER_WEBHOOK_URL=http://localhost:3000/webhooks/indexer
ESCROW_ABI_PATH=../noderails-contracts/out/NodeRailsEscrow.sol/NodeRailsEscrow.json
# JSON map chain ID to deployed address, for example {"11155111":"0x...","80002":"0x..."}
ESCROW_DEPLOYMENTS=

# ============ Blockchain / Contracts ============
# Deployer & role management (for Foundry scripts)
DEPLOYER_PRIVATE_KEY=
SUPER_ADMIN_ADDRESS=
ETHERSCAN_API_KEY=

# Role setup (SetupRoles.s.sol)
SUPER_ADMIN_PRIVATE_KEY=
ESCROW_ADDRESS=
MERCHANT_MANAGER_ADDRESS=
ADMIN_ADDRESS=
TRANSACTION_KEY_ADDRESS=

# RPC
LEANRPC_API_KEY=