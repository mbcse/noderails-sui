{
  "name": "@noderails/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Database client and Prisma schema for NodeRails",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm generate && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist src/generated",
    "generate": "prisma generate",
    "push": "prisma db push",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "reset" : "prisma migrate reset",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "prisma": "^7.3.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
