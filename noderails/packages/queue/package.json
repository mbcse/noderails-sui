{
  "name": "@noderails/queue",
  "version": "0.1.0",
  "private": true,
  "description": "Pluggable queue abstraction for NodeRails - currently backed by BullMQ",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./adapters/bullmq": {
      "types": "./dist/adapters/bullmq.d.ts",
      "import": "./dist/adapters/bullmq.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "bullmq": "^5.7.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@noderails/common": "workspace:*"
  }
}
