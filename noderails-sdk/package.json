{
  "name": "@noderails/sdk",
  "version": "0.1.0",
  "description": "NodeRails — Crypto payments SDK for Node.js, Deno, and Bun",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:e2e": "vitest run --config vitest.config.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "noderails",
    "crypto",
    "payments",
    "checkout",
    "sdk",
    "web3",
    "blockchain",
    "escrow"
  ],
  "author": "NodeRails",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
